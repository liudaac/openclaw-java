<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="chatContainer" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="openclaw.desktop.controller.ChatController"
            styleClass="chat-container">

    <!-- Header -->
    <top>
        <HBox styleClass="chat-header" spacing="12" alignment="CENTER_LEFT">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16" />
            </padding>

            <Label text="Chat" styleClass="chat-title" />

            <HBox HBox.hgrow="ALWAYS" />

            <ComboBox fx:id="modelSelector" styleClass="model-selector" />

            <Label fx:id="tokenUsageLabel" styleClass="token-usage" />
        </HBox>
    </top>

    <!-- Messages -->
    <center>
        <ListView fx:id="messageList" styleClass="message-list" VBox.vgrow="ALWAYS" />
    </center>

    <!-- Input Area -->
    <bottom>
        <VBox spacing="8" styleClass="input-container">
            <padding>
                <Insets top="12" right="16" bottom="16" left="16" />
            </padding>

            <!-- Attachments Container -->
            <VBox fx:id="attachmentsContainer" spacing="8" visible="false">
                <padding>
                    <Insets bottom="8" />
                </padding>
            </VBox>

            <!-- Progress Bar (hidden by default) -->
            <ProgressBar fx:id="streamingProgress" styleClass="streaming-progress" visible="false" maxWidth="Infinity" />

            <!-- Input Toolbar -->
            <HBox fx:id="inputToolbar" spacing="8" alignment="CENTER_LEFT">
                <Button fx:id="attachButton" styleClass="toolbar-button">
                    <graphic>
                        <FontIcon iconLiteral="mdi2p-paperclip" iconSize="18" />
                    </graphic>
                </Button>

                <Button styleClass="toolbar-button">
                    <graphic>
                        <FontIcon iconLiteral="mdi2m-microphone" iconSize="18" />
                    </graphic>
                </Button>
            </HBox>

            <!-- Input Field -->
            <HBox spacing="8" alignment="BOTTOM_CENTER">
                <TextArea fx:id="inputArea" promptText="Type your message here... (Shift+Enter for new line)"
                          styleClass="input-area" wrapText="true" HBox.hgrow="ALWAYS" />

                <VBox spacing="8" alignment="BOTTOM_CENTER">
                    <Button fx:id="abortButton" styleClass="abort-button" visible="false">
                        <graphic>
                            <FontIcon iconLiteral="mdi2s-stop" iconSize="18" />
                        </graphic>
                    </Button>

                    <Button fx:id="sendButton" styleClass="send-button" defaultButton="true">
                        <graphic>
                            <FontIcon iconLiteral="mdi2s-send" iconSize="18" />
                        </graphic>
                    </Button>
                </VBox>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
