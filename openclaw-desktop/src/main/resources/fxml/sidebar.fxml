<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="sidebarRoot" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="openclaw.desktop.controller.SidebarController"
      styleClass="sidebar">

    <!-- Header -->
    <HBox styleClass="sidebar-header" spacing="8" alignment="CENTER_LEFT">
        <padding>
            <Insets top="16" right="16" bottom="16" left="16" />
        </padding>

        <Label text="OpenClaw" styleClass="sidebar-title" />
    </HBox>

    <!-- New Chat Button -->
    <HBox spacing="8" alignment="CENTER">
        <padding>
            <Insets top="8" right="16" bottom="8" left="16" />
        </padding>

        <Button fx:id="newChatButton" text="New Chat" styleClass="new-chat-button" maxWidth="Infinity" HBox.hgrow="ALWAYS">
            <graphic>
                <FontIcon iconLiteral="mdi2p-plus" iconSize="18" />
            </graphic>
        </Button>
    </HBox>

    <!-- Search -->
    <HBox spacing="8" alignment="CENTER">
        <padding>
            <Insets top="8" right="16" bottom="8" left="16" />
        </padding>

        <TextField fx:id="searchField" promptText="Search conversations..." styleClass="search-field" HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- Conversation List -->
    <ListView fx:id="conversationList" VBox.vgrow="ALWAYS" styleClass="conversation-list" />

    <!-- Navigation -->
    <VBox fx:id="navButtons" spacing="4" styleClass="nav-buttons">
        <padding>
            <Insets top="8" right="8" bottom="8" left="8" />
        </padding>

        <Button fx:id="chatNavButton" text="Chat" styleClass="nav-button">
            <graphic>
                <FontIcon iconLiteral="mdi2m-message-text" iconSize="20" />
            </graphic>
        </Button>

        <Button fx:id="toolsNavButton" text="Tools" styleClass="nav-button">
            <graphic>
                <FontIcon iconLiteral="mdi2t-tools" iconSize="20" />
            </graphic>
        </Button>

        <Button fx:id="settingsNavButton" text="Settings" styleClass="nav-button">
            <graphic>
                <FontIcon iconLiteral="mdi2c-cog" iconSize="20" />
            </graphic>
        </Button>
    </VBox>

    <!-- Footer -->
    <HBox styleClass="sidebar-footer" alignment="CENTER">
        <padding>
            <Insets top="8" right="16" bottom="8" left="16" />
        </padding>

        <Label fx:id="versionLabel" text="v2026.3.24" styleClass="version-label" />
    </HBox>

</VBox>
